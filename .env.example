NOVA_AGENT_PORT=8787

# Web UI: default 3000. NOVA_WEB_STANDARD_PORTS=1 uses 80 (HTTP) or 443 (HTTPS) when NOVA_WEB_PORT is unset (80/443 often need sudo).
# NOVA_WEB_STANDARD_PORTS=1
# NOVA_WEB_HTTPS=true
# For LAN HTTPS + microphone: add your host IP, e.g. NOVA_WEB_TLS_SAN=IP:192.168.1.10,DNS:myhost.local
# NOVA_WEB_TLS_SAN=
NOVA_API_TOKEN=change-me
NOVA_SETTINGS_SECRET=change-me

# Chat mic → text (agent-core). If NOVA_STT_COMMAND is unset, OPENAI_API_KEY enables OpenAI Whisper on /v1/voice/transcribe-audio.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com
# NOVA_WHISPER_MODEL=whisper-1
# Shell STT override: argv[1] = audio file path, stdout = transcript (used when set, instead of Whisper).
# NOVA_STT_COMMAND=

# Firebase Admin SDK service account JSON path (backend push delivery)
NOVA_FIREBASE_ADMIN_CREDENTIALS_PATH=./api_keys/nova-b006d-firebase-adminsdk-fbsvc-xxxxxxxxxxxx.json

# Mobile app base URL for local emulator/simulator usage
# Android emulator: http://10.0.2.2:8787
# iOS simulator: http://127.0.0.1:8787
NOVA_MOBILE_API_BASE_URL=http://127.0.0.1:8787

# Keep local Ollama model loaded between idle/background cycles (examples: 5m, 30m, 2h, -1)
NOVA_OLLAMA_KEEP_ALIVE=30m
# Optional override for Ollama think: true|false|1|0. When unset, Nova uses Settings → Models → Ollama native thinking.
# NOVA_OLLAMA_THINK=false

# Force-disable or force-enable Ollama/LM Studio routing (when unset, uses Settings → Models → Disabled toggles).
# NOVA_OLLAMA_DISABLED=true
# NOVA_LMSTUDIO_DISABLED=true

# Optional default Perplexica endpoint for the Perplexica Web Search skill.
# NOVA_PERPLEXICA_BASE_URL=http://127.0.0.1:3008

# LM Studio REST unload (Settings → Vision → unload chat model): optional bearer if your server requires auth.
# LMSTUDIO_API_KEY=
# LM_API_TOKEN=

# Optional override for skill subprocess isolation (when unset, uses Settings → General → Skills execution).
# NOVA_SKILL_ISOLATION=true

GITHUB_TOKEN=github_pat_TOKEN_HERE

# When true, agent-core disables Copilot routing regardless of Settings UI (headless servers).
# NOVA_COPILOT_DISABLED=true

# Copilot device login (`npm run login -- --provider=github-copilot`): optional overrides.
# Client id defaults to GitHub's public Copilot device-flow id (OpenClaw / VS Code style — no OAuth app to create).
# NOVA_GITHUB_OAUTH_CLIENT_ID=
# Default scope if unset: read:user user:email copilot
# NOVA_GITHUB_OAUTH_SCOPE=

# Set to true to block chat-driven workspace skill authoring (plan/code under skills/).
# NOVA_SKILL_AUTHORING_DISABLED=true

# In-app update apply: by default only `git pull` + `pnpm install` (safe while `next dev` runs).
# Set true to also run `pnpm -r build` — stop the web dev server first or you can corrupt apps/web/.next.
# NOVA_UPDATE_INCLUDE_BUILD=true