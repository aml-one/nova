NOVA_AGENT_PORT=8787
NOVA_API_TOKEN=change-me
NOVA_SETTINGS_SECRET=change-me

# Firebase Admin SDK service account JSON path (backend push delivery)
NOVA_FIREBASE_ADMIN_CREDENTIALS_PATH=./api_keys/nova-b006d-firebase-adminsdk-fbsvc-xxxxxxxxxxxx.json

# Mobile app base URL for local emulator/simulator usage
# Android emulator: http://10.0.2.2:8787
# iOS simulator: http://127.0.0.1:8787
NOVA_MOBILE_API_BASE_URL=http://127.0.0.1:8787

# Keep local Ollama model loaded between idle/background cycles (examples: 5m, 30m, 2h, -1)
NOVA_OLLAMA_KEEP_ALIVE=30m


GITHUB_TOKEN=github_pat_TOKEN_HERE