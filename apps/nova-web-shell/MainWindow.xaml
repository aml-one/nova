<Window x:Class="Nova.WebShell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Nova"
        Icon="pack://application:,,,/images/nova_icon.ico"
        Height="900"
        Width="1400"
        MinHeight="480"
        MinWidth="720"
        PreviewKeyDown="Window_PreviewKeyDown"
        Loaded="Window_Loaded">
  <DockPanel>
    <DockPanel x:Name="ChromeHeader" DockPanel.Dock="Top" LastChildFill="True">
      <TextBlock x:Name="StatusUrl"
                 DockPanel.Dock="Right"
                 VerticalAlignment="Center"
                 Margin="10,0,14,0"
                 MaxWidth="560"
                 TextWrapping="NoWrap"
                 TextTrimming="CharacterEllipsis"
                 FontSize="11"
                 Opacity="0.88" />
      <Menu x:Name="TopMenu" Background="Transparent">
        <MenuItem Header="_File">
          <MenuItem Header="_Reload Web UI" Click="Reload_Click" InputGestureText="F5" />
          <Separator />
          <MenuItem Header="E_xit" Click="Exit_Click" />
        </MenuItem>
        <MenuItem Header="_View">
          <MenuItem Header="_Developer tools" Click="DevTools_Click" InputGestureText="F12" />
        </MenuItem>
        <MenuItem Header="_About" Click="About_Click" />
      </Menu>
    </DockPanel>
    <wv2:WebView2 x:Name="WebView" />
  </DockPanel>
</Window>
