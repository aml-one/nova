<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.aml.nova.web</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/env</string>
    <string>corepack</string>
    <string>pnpm</string>
    <string>--filter</string>
    <string>@nova/web</string>
    <string>start</string>
    <string>--</string>
    <string>-p</string>
    <string>3000</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__NOVA_PATH__</string>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>__NOVA_PATH__/data/logs/web.out.log</string>
  <key>StandardErrorPath</key>
  <string>__NOVA_PATH__/data/logs/web.err.log</string>
</dict>
</plist>
