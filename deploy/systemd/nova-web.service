[Unit]
Description=Nova Web UI
After=network.target nova-agent-core.service

[Service]
Type=simple
WorkingDirectory=__NOVA_PATH__
Environment=NODE_ENV=production
Environment=PORT=3000
ExecStart=/usr/bin/env corepack pnpm --filter @nova/web start -- -p 3000
Restart=always
RestartSec=5
User=__USER__
Group=__USER__

[Install]
WantedBy=multi-user.target
